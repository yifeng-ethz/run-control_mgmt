 <!-- NOTE 2026-04-16: removed upload_system_jtag_master.master_reset feedback
      connections into the AVMM fabric. On this bitstream the JTAG master's
      master_reset output stays asserted after system-console claim_service,
      which kept runctl_mgmt_host_0.mm_reset / csr_bridge / upload_cdc_fifo /
      upload_pkt_mux permanently in reset and stalled every master_read_32 at
      60 s. Diagnosed in T002_RC-REG_20260416/reports/run_20260416_blocker.log.
      The system clock-domain resets (control_plane_clock_156.clk_reset and
      data_path_clock_125.clk_reset) are the only reset sources now, which is
      sufficient for power-up and for feb_system_v2's external reset tree. -->
 <interconnectRequirement for="$system" name="qsys_mm.clockCrossingAdapter" value="HANDSHAKE" />
 <interconnectRequirement for="$system" name="qsys_mm.enableEccProtection" value="FALSE" />
 <interconnectRequirement for="$system" name="qsys_mm.insertDefaultSlave" value="FALSE" />
 <interconnectRequirement for="$system" name="qsys_mm.maxAdditionalLatency" value="1" />
</system>
