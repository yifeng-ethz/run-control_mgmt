			hit_type_1_data                    : in  std_logic_vector(38 downto 0) := (others => 'X'); -- data
			ring_buffer_cam_0_csr_readdata     : out std_logic_vector(31 downto 0);                    -- readdata
			ring_buffer_cam_0_csr_read         : in  std_logic                     := 'X';             -- read
			ring_buffer_cam_0_csr_address      : in  std_logic_vector(4 downto 0)  := (others => 'X'); -- address
			ring_buffer_cam_0_csr_waitrequest  : out std_logic;                                        -- waitrequest
