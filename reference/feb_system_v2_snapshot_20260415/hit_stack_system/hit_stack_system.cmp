			ring_buffer_cam_0_filllevel_data   : out std_logic_vector(15 downto 0);                    -- data
			ring_buffer_cam_0_filllevel_valid  : out std_logic;                                        -- valid
			ring_buffer_cam_1_csr_readdata     : out std_logic_vector(31 downto 0);                    -- readdata
